# Copy to .env and fill in your values.
# .env is gitignored — never commit credentials.

# Robot connection
SESAME_ROBOT_IP=sesame-robot.local  # or IP address, e.g. 192.168.1.42

# LLM — local Ollama (default, no API key needed)
SESAME_LOCAL=true
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2           # or granite3.1-dense:8b, mistral, etc.
WHISPER_MODEL=small                # STT model: tiny/base/small/medium — small handles the robot's muffled mic

# Voice settings
VOICE_ENABLED=true
TTS_ENGINE=pyttsx3                 # pyttsx3 (local) | gemini (requires GEMINI_API_KEY)
WAKE_WORD=hey sesame
WAKE_WORD_MODE=false               # true = listen for wake word on laptop mic

# Quick response layer — pre-LLM instant responses (jokes, animal sounds, simple Q&A)
QUICK_MODE=true

# Vision (camera stream from robot on port 8891)
VISION_PASSIVE=true      # enable always-on passive reactions (peek-a-boo, wave, face close)
VISION_TIMEOUT=30        # seconds before active mode auto-stops and returns to passive

# Optional: Gemini (only needed if SESAME_LOCAL=false or TTS_ENGINE=gemini)
# GEMINI_API_KEY=your_key_here
